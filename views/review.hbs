<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Review {{anime.title}} - Otakurate</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<nav>
    <div class="logo neon">Otakurate</div>

    <div class="nav-links">
        <a href="/">Home</a>
        <a href="/search?search=">Browse</a>
    </div>
</nav>

<div class="hero">

    <h1>
        Review {{anime.title}}
    </h1>

    <p>Share your thoughts and rate this anime.</p>

    <div class="review-box" style="max-width: 600px; margin: 40px auto;">

        <form action="/review/{{anime._id}}" method="POST" style="display: flex; flex-direction: column; gap: 20px;">

            <div>
                <label for="rating" style="color: #ff8fa2; font-weight: 700; display: block; margin-bottom: 10px;">
                    Rating (1-10)
                </label>
                <input
                    id="rating"
                    name="rating"
                    type="number"
                    placeholder="Rate out of 10"
                    min="1"
                    max="10"
                    required
                    style="width: 100%; padding: 14px; border: 2px solid rgba(255, 73, 106, 0.3); border-radius: 12px; background: rgba(255, 255, 255, 0.05); color: white; font-size: 16px; outline: none; transition: all 0.3s ease;"
                    onfocus="this.style.borderColor = '#ff496a'; this.style.boxShadow = '0 0 20px rgba(255, 73, 106, 0.3)';"
                    onblur="this.style.borderColor = 'rgba(255, 73, 106, 0.3)'; this.style.boxShadow = 'none';"
                >
            </div>

            <div>
                <label for="comment" style="color: #ff8fa2; font-weight: 700; display: block; margin-bottom: 10px;">
                    Your Review
                </label>
                <textarea
                    id="comment"
                    name="comment"
                    placeholder="Share your thoughts about this anime... What did you love? What could be better?"
                    required
                    style="width: 100%; padding: 14px; border: 2px solid rgba(255, 73, 106, 0.3); border-radius: 12px; background: rgba(255, 255, 255, 0.05); color: white; font-family: inherit; font-size: 14px; outline: none; transition: all 0.3s ease; min-height: 150px; resize: vertical;"
                    onfocus="this.style.borderColor = '#ff496a'; this.style.boxShadow = '0 0 20px rgba(255, 73, 106, 0.3)';"
                    onblur="this.style.borderColor = 'rgba(255, 73, 106, 0.3)'; this.style.boxShadow = 'none';"
                ></textarea>
            </div>

            <button type="submit" style="padding: 16px 35px; border: none; background: linear-gradient(135deg, #ff496a, #9b3f7f); color: #fff; border-radius: 50px; cursor: pointer; font-weight: 700; font-size: 16px; transition: all 0.3s ease; box-shadow: 0 4px 20px rgba(255, 73, 106, 0.3);"
                onmouseover="this.style.transform = 'translateY(-2px)'; this.style.boxShadow = '0 8px 30px rgba(255, 73, 106, 0.5)';"
                onmouseout="this.style.transform = 'translateY(0)'; this.style.boxShadow = '0 4px 20px rgba(255, 73, 106, 0.3)';">
                Submit Review
            </button>

        </form>

    </div>

</div>

</body>
</html>